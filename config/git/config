[core]
	editor = nvim

[diff]
	algorithm = histogram
	colorMoved = default

[fetch]
	prune = true

[merge]
	conflictStyle = zdiff3

[pull]
	ff = only

[push]
	default = current

[rebase]
	autostash = true
	autosquash = true

[rerere]
	enabled = true

[init]
	defaultbranch = main

[ghq]
	root = ~/ghq

[alias]
	logo = log --oneline
	s = status --untracked-files

[commit]
	gpgsign = true

[gpg]
	format = ssh

[user]
	name = tsunematsu21
	email = tsunematsu21@users.noreply.github.com
	signingkey = ~/.ssh/id_ed25519_tsunematsu21.pub

[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
